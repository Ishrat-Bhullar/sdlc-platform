DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ey_sdlc_studio
JWT_SECRET=change-me
PORT=8000
FRONTEND_URL=http://localhost:5173
DEMO_MODE=false

# ── Platform default LLM (deployment-wide) ────────────────────────────────
# Resolution order (see agents/llm_service.py): BYOK -> Azure OpenAI -> Groq
# -> OpenAI -> Ollama. Configure ONLY the tier you want active; leaving a
# tier's key blank makes the chain skip it automatically, zero code changes.

# Primary/demo provider — fill these in for the real EY demo. The moment
# DEFAULT_AZURE_OPENAI_API_KEY is set, Azure takes over from Groq automatically.
DEFAULT_AZURE_OPENAI_API_KEY=
DEFAULT_AZURE_OPENAI_ENDPOINT=
DEFAULT_AZURE_OPENAI_DEPLOYMENT=
DEFAULT_AZURE_OPENAI_API_VERSION=2024-06-01

# Temporary development/testing provider only — tried when Azure above is not
# configured. Fast + cheap. llama-3.1-8b-instant is an even faster alternative
# to the default model below if latency matters more than quality during dev.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback provider — tried only if Azure and Groq are both unconfigured/failed.
DEFAULT_OPENAI_API_KEY=
DEFAULT_OPENAI_BASE_URL=

# ── Presentation Studio image generation (Azure OpenAI only) ──────────────
# Used only by the presentation pipeline's hero-image step (agents/
# image_provider.py). Point this at whatever image-generation deployment you
# created on Azure OpenAI (e.g. a gpt-image-1 or dall-e-3 deployment) — no
# specific model is assumed. Leave blank to skip hero images entirely; slides
# still render fully via their existing gradients/icons/diagrams/layouts.
AZURE_OPENAI_IMAGE_API_KEY=
AZURE_OPENAI_IMAGE_ENDPOINT=
AZURE_OPENAI_IMAGE_DEPLOYMENT=
AZURE_OPENAI_IMAGE_API_VERSION=2024-04-01-preview
